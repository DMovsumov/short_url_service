# PostgreSQL Config
POSTGRES_USER=shorturl
POSTGRES_PASSWORD=shorturl_secret
POSTGRES_DB=shorturl_db
POSTGRES_PORT=5432

# Database URL (required for local development)
DATABASE_URL=postgresql+asyncpg://shorturl:shorturl_secret@postgres:5432/shorturl_db

# Redis Config
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Application Config
APP_PORT=8000
DEBUG=false
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# CORS
CORS_ALLOW_ORIGINS=http://localhost:8000
CORS_ALLOW_CREDENTIALS=false

# Short URL Config
SHORT_CODE_LENGTH=6
SHORT_URL_BASE=http://localhost:8000

# Cookie Config
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
